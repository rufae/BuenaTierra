# ============================================================
# BuenaTierra - Variables de Entorno
# Copiar este fichero como .env y rellenar los valores reales
# NUNCA subir .env a Git
# ============================================================

# PostgreSQL
POSTGRES_DB=buenatierra
POSTGRES_USER=buenatierra_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# JWT (mínimo 64 caracteres aleatorios)
JWT_SECRET=CHANGE_ME_JWT_SECRET_64_CHARS_MIN_RANDOM_STRING_HERE_ABCDEF123456

# Entorno API
ASPNETCORE_ENVIRONMENT=Production
