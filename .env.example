# ============================================================
# BuenaTierra - Variables de Entorno
# Copiar este fichero como .env y rellenar los valores reales
# NUNCA subir .env a Git
# ============================================================

# PostgreSQL
POSTGRES_DB=buenatierra
POSTGRES_USER=buenatierra_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# JWT (mínimo 64 caracteres aleatorios)
JWT_SECRET=CHANGE_ME_JWT_SECRET_64_CHARS_MIN_RANDOM_STRING_HERE_ABCDEF123456

# Entorno API
ASPNETCORE_ENVIRONMENT=Production

# BuenaTierrAI (integración IA segura por API key)
# Opción OpenAI:
# BUENATIERRAI_PROVIDER_BASE_URL=https://api.openai.com/v1
# BUENATIERRAI_MODEL=gpt-4o-mini
# BUENATIERRAI_API_KEY=sk-CHANGE_ME_OPENAI_KEY
#
# Opción Groq (OpenAI-compatible API):
# BUENATIERRAI_PROVIDER_BASE_URL=https://api.groq.com/openai/v1
# BUENATIERRAI_MODEL=llama-3.3-70b-versatile
# BUENATIERRAI_API_KEY=gsk_CHANGE_ME_GROQ_KEY
BUENATIERRAI_ENABLED=true
BUENATIERRAI_PROVIDER_BASE_URL=https://api.openai.com/v1
BUENATIERRAI_MODEL=gpt-4o-mini
BUENATIERRAI_API_KEY=CHANGE_ME_BUENATIERRAI_PROVIDER_KEY
